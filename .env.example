# Public Supabase keys (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xyxyqtomvsqqfdembomk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# n8n webhook URLs. See docs/n8n-webhook-specs.md for what each one does.
# NEXT_PUBLIC_ prefix = called from the browser (Bot Factory during onboarding).
# Bare vars = called from Server Actions (server-only, safer).
# -----------------------------------------------------------------------------

# Bot Factory — onboarding wizard POSTs here to create a new bot.
NEXT_PUBLIC_BOT_FACTORY_WEBHOOK_URL=https://aurasmsg.app.n8n.cloud/webhook/bc34973e-8eec-48c8-8158-ae6fa929acef

# Save FAQ — insert/update/delete FAQ + trigger prompt rebuild.
N8N_SAVE_FAQ_URL=https://aurasmsg.app.n8n.cloud/webhook/replace-me-save-faq

# Ingest Document — download from Storage, extract text, insert doc row, rebuild prompt.
N8N_INGEST_DOC_URL=https://aurasmsg.app.n8n.cloud/webhook/replace-me-ingest-doc

# Rebuild System Prompt — recompose prompt from company info + docs + FAQs.
N8N_REBUILD_PROMPT_URL=https://aurasmsg.app.n8n.cloud/webhook/replace-me-rebuild-prompt

# Update Bot — patch business details / system prompt / takeover.
N8N_UPDATE_BOT_URL=https://aurasmsg.app.n8n.cloud/webhook/replace-me-update-bot

# Shared secret the dashboard sends as Bearer token.
# Generate with: openssl rand -hex 32
AURAS_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32
